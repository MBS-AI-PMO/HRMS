{
	"info": {
		"_postman_id": "b7e8f4a2-3c1d-5e6f-8a9b-0c1d2e3f4a5b",
		"name": "HRMS API",
		"description": "Laravel HRMS API routes from routes/api.php (Sanctum Bearer for protected endpoints). Set collection variable base_url to your app root (e.g. http://hrms.test or http://127.0.0.1:8000). Login request saves token automatically.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://hrms.test"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Public",
			"item": [
				{
					"name": "Is update available",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/api/is-update-available"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"try {",
									"  var json = pm.response.json();",
									"  if (json && json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.test('Token saved', function () { pm.expect(json.token).to.be.a('string'); });",
									"  }",
									"} catch (e) { /* non-json */ }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"your_username\",\n  \"password\": \"your_password\"\n}"
						},
						"url": "{{base_url}}/api/login"
					}
				}
			]
		},
		{
			"name": "Auth (Bearer)",
			"auth": {
				"type": "bearer",
				"bearer": [
					{
						"key": "token",
						"value": "{{token}}",
						"type": "string"
					}
				]
			},
			"item": [
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/api/logout"
					}
				},
				{
					"name": "Profile (GET)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/api/profile"
					}
				},
				{
					"name": "Profile update (PATCH JSON)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"contact_no\": \"03001234567\"\n}"
						},
						"url": "{{base_url}}/api/profile"
					}
				},
				{
					"name": "Profile update (PUT password)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"password\": \"newsecret\",\n  \"password_confirmation\": \"newsecret\"\n}"
						},
						"url": "{{base_url}}/api/profile"
					}
				},
				{
					"name": "Profile update (form-data photo)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "first_name",
									"value": "John",
									"type": "text"
								},
								{
									"key": "profile_photo",
									"type": "file",
									"src": []
								}
							]
						},
						"url": "{{base_url}}/api/profile"
					}
				},
				{
					"name": "Employees list",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/api/employees"
					}
				},
				{
					"name": "Employee details",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/api/employees/1"
					}
				},
				{
					"name": "Administrators list",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/api/administrators"
					}
				},
				{
					"name": "Office info",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/api/office-info"
					}
				},
				{
					"name": "My attendances",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"description": "Optional query: date_from, date_to (Y-m-d). Example: {{base_url}}/api/attendances?date_from=2026-04-01&date_to=2026-04-30",
						"url": "{{base_url}}/api/attendances"
					}
				}
			]
		}
	]
}
